{% extends 'base.html.twig' %}

{% block title %}Commandes{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>Commandes</h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="{{ path('order_create') }}" class="btn btn-primary">Nouvelle Commande</a>
        </div>
    </div>

    {% if orders|length > 0 %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Numéro</th>
                        <th>Client</th>
                        <th>Total</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr>
                            <td><strong>{{ order.orderNumber }}</strong></td>
                            <td>{{ order.customer.customerName }}</td>
                            <td>{{ order.total|number_format(2, ',', ' ') }} €</td>
                            <td>
                                <span class="badge bg-{{ order.status == 'delivered' ? 'success' : (order.status == 'shipped' ? 'info' : (order.status == 'cancelled' ? 'danger' : 'warning')) }}">
                                    {{ order.status }}
                                </span>
                            </td>
                            <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <a href="{{ path('order_show', {id: order.id}) }}" class="btn btn-sm btn-info">Voir</a>
                                <a href="{{ path('order_edit', {id: order.id}) }}" class="btn btn-sm btn-warning">Éditer</a>
                                <form method="POST" action="{{ path('order_delete', {id: order.id}) }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="alert alert-info">Aucune commande trouvée.</div>
    {% endif %}
</div>
{% endblock %}
