{% extends 'base.html.twig' %}

{% block title %}Commande {{ order.orderNumber }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>Commande {{ order.orderNumber }}</h1>
            <hr>

            <div class="row mb-4">
                <div class="col-md-6">
                    <h5>Client</h5>
                    <p>
                        <strong>{{ order.customer.customerName }}</strong><br>
                        {{ order.customer.city }}, {{ order.customer.country }}
                    </p>
                </div>
                <div class="col-md-6">
                    <h5>Détails de la Commande</h5>
                    <p>
                        <strong>Date:</strong> {{ order.createdAt|date('d/m/Y H:i') }}<br>
                        <strong>Statut:</strong> 
                        <span class="badge bg-{{ order.status == 'delivered' ? 'success' : (order.status == 'shipped' ? 'info' : (order.status == 'cancelled' ? 'danger' : 'warning')) }}">
                            {{ order.status }}
                        </span>
                    </p>
                </div>
            </div>

            <h5>Articles</h5>
            {% if order.orderItems|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th>Prix Unitaire</th>
                                <th>Quantité</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in order.orderItems %}
                                <tr>
                                    <td>{{ item.product.name }}</td>
                                    <td>{{ item.unitPrice|number_format(2, ',', ' ') }} €</td>
                                    <td>{{ item.quantity }}</td>
                                    <td>{{ item.lineTotal|number_format(2, ',', ' ') }} €</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="alert alert-info">Aucun article dans cette commande.</div>
            {% endif %}

            <hr>
            <div class="text-end">
                <h4>Total: <strong>{{ order.total|number_format(2, ',', ' ') }} €</strong></h4>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Actions</h5>
                    <div class="d-grid gap-2">
                        <a href="{{ path('order_edit', {id: order.id}) }}" class="btn btn-warning">Modifier</a>
                        
                        {% if order.status != 'delivered' %}
                            <form method="POST" action="{{ path('order_update_status', {id: order.id, status: 'shipped'}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('status' ~ order.id) }}">
                                <button type="submit" class="btn btn-primary w-100">Marquer comme expédiée</button>
                            </form>
                        {% endif %}

                        {% if order.status != 'cancelled' %}
                            <form method="POST" action="{{ path('order_delete', {id: order.id}) }}" onsubmit="return confirm('Êtes-vous sûr ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
                                <button type="submit" class="btn btn-danger w-100">Supprimer</button>
                            </form>
                        {% endif %}
                    </div>
                    <hr>
                    <a href="{{ path('order_index') }}" class="btn btn-secondary w-100">Retour à la liste</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
