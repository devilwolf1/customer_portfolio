{% extends 'base.html.twig' %}

{% block title %}Erreur serveur (500){% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body text-center">
                    <div class="display-1 text-danger mb-4">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <h1 class="card-title h2 mb-3">Erreur serveur</h1>
                    <p class="card-text text-muted mb-4">
                        Une erreur inattendue s'est produite. Nos équipes techniques ont été notifiées.
                    </p>

                    <div class="alert alert-warning" role="alert">
                        <i class="fas fa-info-circle"></i>
                        <strong>Que faire maintenant ?</strong>
                        <ul class="mb-0 mt-2">
                            <li>Essayez de rafraîchir la page</li>
                            <li>Revenez plus tard</li>
                            <li>Contactez le support si le problème persiste</li>
                        </ul>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <button onclick="location.reload()" class="btn btn-warning btn-lg">
                            <i class="fas fa-refresh"></i> Rafraîchir la page
                        </button>
                        <a href="{{ path('home') }}" class="btn btn-primary">
                            <i class="fas fa-home"></i> Retour à l'accueil
                        </a>
                        <button onclick="history.back()" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Page précédente
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
