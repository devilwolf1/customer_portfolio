{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>Mon Profil</h1>
            <hr>

            <div class="card">
                <div class="card-body">
                    <p>
                        <strong>Nom Complet:</strong> {{ user.fullName }}
                    </p>
                    <p>
                        <strong>Email:</strong> {{ user.email }}
                    </p>
                    <p>
                        <strong>Rôles:</strong> 
                        {% for role in user.roles %}
                            <span class="badge bg-primary">{{ role }}</span>
                        {% endfor %}
                    </p>
                    <p>
                        <strong>Statut:</strong>
                        {% if user.isActive %}
                            <span class="badge bg-success">Actif</span>
                        {% else %}
                            <span class="badge bg-danger">Inactif</span>
                        {% endif %}
                    </p>
                    <p>
                        <strong>Membre depuis:</strong> {{ user.createdAt|date('d/m/Y H:i') }}
                    </p>

                    {% if user.apiToken %}
                        <hr>
                        <h5>Token API</h5>
                        <div class="input-group">
                            <input type="text" class="form-control" value="{{ user.apiToken }}" readonly>
                            <button class="btn btn-secondary" type="button" onclick="navigator.clipboard.writeText('{{ user.apiToken }}')">
                                Copier
                            </button>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="mt-4">
                <a href="{{ path('home') }}" class="btn btn-secondary">Retour</a>
                <form method="post" action="{{ path('auth_logout') }}" style="display: inline;">
                    <button type="submit" class="btn btn-danger">Déconnexion</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
