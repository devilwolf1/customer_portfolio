{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h2 class="card-title text-center mb-4">Inscription</h2>

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}

                    <form method="post" action="{{ path('auth_register') }}">
                        <div class="form-group mb-3">
                            <label for="inputFullName" class="form-label">Nom Complet</label>
                            <input type="text" name="full_name" id="inputFullName" class="form-control" required autofocus>
                        </div>

                        <div class="form-group mb-3">
                            <label for="inputEmail" class="form-label">Email</label>
                            <input type="email" name="email" id="inputEmail" class="form-control" required>
                        </div>

                        <div class="form-group mb-3">
                            <label for="inputPassword" class="form-label">Mot de passe</label>
                            <input type="password" name="password" id="inputPassword" class="form-control" required>
                            <small class="form-text text-muted">Minimum 6 caractères</small>
                        </div>

                        <button type="submit" class="btn btn-success w-100">S'enregistrer</button>
                    </form>

                    <hr>
                    <p class="text-center">
                        Déjà inscrit ? <a href="{{ path('auth_login') }}">Se connecter</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
