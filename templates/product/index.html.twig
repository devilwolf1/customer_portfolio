{% extends "base.html.twig" %}

{% block title %}Produits{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-12">
            <h1><i class="fas fa-box"></i> Catalogue des produits</h1>
            
            <!-- Messages Flash -->
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
            
            <div class="mb-4">
                <a href="{{ path('product_create') }}" class="btn btn-primary btn-lg">
                    <i class="fas fa-plus"></i> Ajouter un produit
                </a>
            </div>

            <!-- Filter by Category -->
            <div class="card mb-4 shadow-md">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-filter"></i> Filtrer par catégorie</h5>
                </div>
                <div class="card-body">
                    <div class="btn-group flex-wrap" role="group">
                        <a href="{{ path('product_list') }}" class="btn btn-outline-secondary {% if not selectedCategory %}active{% endif %}">
                            <i class="fas fa-th"></i> Tous
                        </a>
                        {% for category in categories %}
                            <a href="{{ path('product_list', {'category': category.id}) }}" 
                               class="btn btn-outline-secondary {% if selectedCategory == category.id %}active{% endif %}">
                                <i class="fas fa-tag"></i> {{ category.name }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Products Table -->
            {% if products|length > 0 %}
                <div class="card shadow-md">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th><i class="fas fa-hashtag"></i> ID</th>
                                        <th><i class="fas fa-cube"></i> Nom</th>
                                        <th><i class="fas fa-folder"></i> Catégorie</th>
                                        <th><i class="fas fa-euro-sign"></i> Prix</th>
                                        <th><i class="fas fa-warehouse"></i> Quantité</th>
                                        <th><i class="fas fa-calendar"></i> Date</th>
                                        <th><i class="fas fa-cog"></i> Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for product in products %}
                                        <tr>
                                            <td><strong>#{{ product.id }}</strong></td>
                                            <td>{{ product.name }}</td>
                                            <td>
                                                <span class="badge bg-info">{{ product.category.name }}</span>
                                            </td>
                                            <td><strong>{{ product.price|number_format(2, ',', ' ') }} €</strong></td>
                                            <td>
                                                {% if product.quantity > 0 %}
                                                    <span class="badge bg-success"><i class="fas fa-check"></i> {{ product.quantity }}</span>
                                                {% else %}
                                                    <span class="badge bg-danger"><i class="fas fa-exclamation"></i> Rupture</span>
                                                {% endif %}
                                            </td>
                                            <td>{{ product.createdAt|date('d/m/Y H:i') }}</td>
                                            <td>
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a href="{{ path('product_show', {'id': product.id}) }}" class="btn btn-info" title="Voir">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="{{ path('product_edit', {'id': product.id}) }}" class="btn btn-warning" title="Modifier">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form method="POST" action="{{ path('product_delete', {'id': product.id}) }}" style="display:inline;">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Êtes-vous sûr ?')" title="Supprimer">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Pagination -->
                {% if totalPages > 1 %}
                    <nav aria-label="Page navigation" class="mt-4">
                        <ul class="pagination justify-content-center">
                            {% if currentPage > 1 %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('product_list', {'page': currentPage - 1, 'category': selectedCategory}) }}">
                                        <i class="fas fa-chevron-left"></i> Précédent
                                    </a>
                                </li>
                            {% endif %}

                            {% for i in 1..totalPages %}
                                <li class="page-item {% if i == currentPage %}active{% endif %}">
                                    <a class="page-link" href="{{ path('product_list', {'page': i, 'category': selectedCategory}) }}">
                                        {{ i }}
                                    </a>
                                </li>
                            {% endfor %}

                            {% if currentPage < totalPages %}
                                <li class="page-item">
                                    <a class="page-link" href="{{ path('product_list', {'page': currentPage + 1, 'category': selectedCategory}) }}">
                                        Suivant <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            {% endif %}
                        </ul>
                    </nav>
                {% endif %}
            {% else %}
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    <i class="fas fa-info-circle"></i> Aucun produit trouvé.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
