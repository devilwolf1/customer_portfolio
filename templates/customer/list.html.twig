{% extends 'base.html.twig' %}

{% block title %}Liste des clients{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <h1 class="mb-4"><i class="fas fa-users"></i> Nos clients</h1>

    {% if data|length > 0 %}
        <div class="card shadow-md">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th><i class="fas fa-id-badge"></i> Identifiant</th>
                                <th><i class="fas fa-user"></i> Nom</th>
                                <th><i class="fas fa-globe"></i> Pays</th>
                                <th><i class="fas fa-city"></i> Ville</th>
                                <th><i class="fas fa-envelope"></i> Code Postal</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for client in data %}
                                <tr>
                                    <td><code class="text-primary">{{ client.customer_id }}</code></td>
                                    <td><strong>{{ client.customer_name }}</strong></td>
                                    <td>{{ client.country }}</td>
                                    <td>{{ client.city }}</td>
                                    <td>{{ client.postal_code }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="fas fa-info-circle"></i> Aucun client trouvé.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}
</div>
{% endblock %}
